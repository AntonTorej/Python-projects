    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import requests\n",
    "import datetime as dt\n",
    "import yfinance as yf\n",
    "import seaborn as sns\n",
    "\n",
    "ticker_list = {'AAPL' : 'Apple',\n",
    "               'JPM' : 'JPMorgan',\n",
    "               'XOM' : 'Exxon mobil',\n",
    "               'PG' : 'Procter & Gmable',\n",
    "               'NVDA' : 'NVIDIA',\n",
    "              }\n",
    "start = dt.datetime(2021, 1, 1)\n",
    "end = dt.datetime(2021, 12, 31)\n",
    "ticker = pd.DataFrame()\n",
    "for tick in ticker_list:\n",
    "    stock = yf.Ticker(tick)\n",
    "    prices = stock.history(start=start, end=end)\n",
    "\n",
    "    closing_prices = prices['Close']\n",
    "    ticker[tick] = closing_prices\n",
    "\n",
    "#Returns\n",
    "log_Return = np.log(ticker / ticker.shift(1))\n",
    "log_Return = log_Return.dropna()\n",
    "cumulative = np.exp(log_Return.cumsum())\n",
    "simple_return = ticker.pct_change().dropna()\n",
    "portfolio_returns = simple_return @ weight\n",
    "\n",
    "#Plot cumulative returns of individual stock\n",
    "cumulative.plot(figsize= (10, 6), title=\"Per stock growth of 1$ - 2021\")\n",
    "plt.grid(alpha = 0.3)\n",
    "plt.ylabel(\"Value of 1$\")\n",
    "plt.axhline(1.0, color = 'black', linewidth = 0.5, linestyle='--')\n",
    "plt.show()\n",
    "\n",
    "#Weight\n",
    "weight = np.array([0.1, 0.3, 0.2, 0.2, 0.2])\n",
    "\n",
    "#Risk\n",
    "cov_matrix = simple_return.cov() * 252\n",
    "corr_matrix = simple_return.corr()\n",
    "contr_vol = weight * (cov_matrix @ weight)\n",
    "\n",
    "#Summary Table\n",
    "Summary = pd.DataFrame({ 'Ann. Return': simple_return.mean() * 252,\n",
    "                         'Ann. Volatility': simple_return.std() * np.sqrt(252),\n",
    "                         'Sharpe': (simple_return.mean() * 252) / (simple_return.std() * np.sqrt(252)),\n",
    "                         'Total returns': (ticker.iloc[-1] / ticker.iloc[0]) - 1,\n",
    "                       })\n",
    "print(Summary.T)\n",
    "\n",
    "#Comparison to S&P 500\n",
    "portfolio_cumulative = (1 + portfolio_returns).cumprod()\n",
    "closing_1 = yf.Ticker('SPY').history(start=start, end=end)['Close']\n",
    "\n",
    "SPY_cumulative = (1 + closing_1.pct_change().dropna()).cumprod()\n",
    "\n",
    "combined = pd.DataFrame({ 'Combined Returns': portfolio_cumulative,\n",
    "                          'S&P': SPY_cumulative,\n",
    "                        })\n",
    "combined.plot(figsize= (10, 6), title = \"portfolio against S&P growth of 1$ - 2021\")\n",
    "plt.ylabel(\"value of 1$\")\n",
    "plt.grid(alpha = 0.3)\n",
    "plt.axhline(1.0, color = 'black', linewidth = 0.5, linestyle='--')\n",
    "plt.show()\n",
    "\n",
    "#Correlation matrix\n",
    "plt.figure(figsize= (8, 6))\n",
    "sns.heatmap(corr_matrix, annot=True, cmap='RdBu_r', vmin=-1, vmax=1, center=0)\n",
    "plt.title(\"Daily returns correlation - 2021\")\n",
    "plt.show()     "
   ]
